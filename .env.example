# ──────────────────────────────────────────────────
#  LuggageTrack Environment Variables
#  Copy this file to .env and fill in your values
#  NEVER commit the actual .env to git
# ──────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────
POSTGRES_DB=luggagetrack
POSTGRES_USER=luggagetrack
POSTGRES_PASSWORD=ChangeMe_StrongPassword123!

# ── JWT ───────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-a-very-long-random-secret-string

# ── CORS ─────────────────────────────────────────
# Set to your domain in production, e.g. https://yourdomain.com
CORS_ORIGIN=*

# ── Certbot / Let's Encrypt ───────────────────────
# Your registered domain name pointing to this EC2 IP
DOMAIN=yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com
